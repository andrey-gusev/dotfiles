{
    "position": "bottom",
    "height": 20,
    "margin": 0,
    "no-center": true,
    "expand-left": true,
    "reload_style_on_change": true,
    "spacing": 0,
    "modules-left": [
        "hyprland/workspaces", 
        "hyprland/window"
    ],
    "modules-center": [],
    "modules-right": [
        //"custom/playerctl",
        //"custom/wttr",
        "hyprland/language",
        "pulseaudio",
        "disk",
        "cpu",
        "memory", 
        "upower", 
        "network", 
        "clock"
        //"tray"
    ],

    "tray": {
        "icon-size": 14,
        "spacing": 5
    },
    "hyprland/window": {
        "icon": true,
        "icon-size": 14,
    },
    "hyprland/language": {
        "format-en": "US",
        "format-ru": "RU"
    },
    "clock": {
        "interval": 1,
        "timezone": "Asia/Yekaterinburg",
        "format": "{:%Y-%m-%d %R:%S}",
        "tooltip": false
    },
    "custom/clock": {
        "exec": "LC_TIME=ru_RU.UTF-8 date '+%a, %d %b %H:%M'",
        "interval": 60,
    },
    "cpu": {
        "format": "C:{usage}%",
        "tooltip": false
    },
    "memory": {
        "interval": 2,
        "format": "M:{used:0.1f}/{total:0.1f}G",
        "tooltip": false
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 25,
            "critical": 15
        },
    	"format": "B:{capacity}%",
        "format-charging": "AC:{capacity}%",
        "interval": 10
    },
    "upower": {
        "format": "B:{percentage}",
        "show-icon": false,
        "tooltip-spacing": 0
    },
    "disk": {
        "interval": 30,
        "format": "D:{specific_used:0.1f}/{specific_total:0.1f}G",
        "path": "/",
        "unit": "GB"
    },
    "network": {
        "interval": 2,
        "format-wifi": "{essid}:{signalStrength}% IP:{ipaddr}",
        "format-ethernet": "IP:{ipaddr}",
        "format-linked": "{ifname} (No IP)",
        "format-disconnected": "DIS",
        "format-alt": "{bandwidthDownBits:>} {bandwidthUpBits:>}",
        "tooltip-format": "{ifname}"
    },
    "pulseaudio": {
        "format": "V:{volume}%",
        "format-muted": "MUTE",
        "format-bluetooth": "B:{volume}%",
        "on-click": "pulsemixer"
    },
    "custom/playerctl": {
        "format": "{}",
        "exec": "playerctl metadata --format '{{ artist }} — {{ title }}' | awk -F' — ' '{if(length($1) > 30) print substr($1, 1, 27) \"...\" \" — \"$2; else print $0}'",
        "interval": 1,
        "return-type": "text",
        "on-click": "playerctl play-pause"
    },
    "custom/wttr": {
        "exec": "wttr",
        "interval": 600,
    },
}
