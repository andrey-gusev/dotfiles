[Default Applications]
# --- Веб и Схемы (Браузер) ---
text/html=libreoffice.desktop
x-scheme-handler/http=libreoffice.desktop
x-scheme-handler/https=libreoffice.desktop
x-scheme-handler/about=libreoffice.desktop
x-scheme-handler/unknown=libreoffice.desktop
x-scheme-handler/mailto=thunderbird.desktop
x-scheme-handler/magnet=transmission-gtk.desktop

# --- Файловый менеджер ---
inode/directory=lf.desktop

# --- Текст и Код ---
text/plain=nvim.desktop
text/x-shellscript=nvim.desktop
text/xml=nvim.desktop
text/markdown=nvim.desktop
text/javascript=nvim.desktop
text/x-python=nvim.desktop
text/md=nvim.desktop
application/json=nvim.desktop
application/x-yaml=nvim.desktop

# --- Документы ---
application/pdf=org.pwmt.zathura.desktop
application/djvu=org.pwmt.zathura.desktop
application/postscript=zathura.desktop
application/epub+zip=org.pwmt.zathura.desktop

# --- Изображения ---
image/jpeg=nsxiv.desktop
image/png=nsxiv.desktop
image/gif=nsxiv.desktop
image/heic=nsxiv.desktop
image/webp=nsxiv.desktop
image/bmp=nsxiv.desktop
image/tiff=nsxiv.desktop
image/svg+xml=nsxiv.desktop

# --- Видео ---
video/mp4=mpv.desktop
video/x-matroska=mpv.desktop
video/webm=mpv.desktop
video/quicktime=mpv.desktop
video/x-msvideo=mpv.desktop

# --- Аудио ---
audio/mpeg=mpv.desktop
audio/flac=mpv.desktop
audio/wav=mpv.desktop
audio/ogg=mpv.desktop
audio/x-vorbis+ogg=mpv.desktop

# --- Архивы ---
application/zip=org.gnome.FileRoller.desktop
application/x-7z-compressed=org.gnome.FileRoller.desktop
application/x-rar-compressed=org.gnome.FileRoller.desktop
application/x-tar=org.gnome.FileRoller.desktop
application/x-bzip2=org.gnome.FileRoller.desktop
application/x-gzip=org.gnome.FileRoller.desktop
application/x-xz=org.gnome.FileRoller.desktop

# --- Офис ---
application/vnd.openxmlformats-officedocument.wordprocessingml.document=libreoffice-writer.desktop
application/msword=libreoffice-writer.desktop
application/vnd.openxmlformats-officedocument.spreadsheetml.sheet=libreoffice-calc.desktop
application/vnd.ms-excel=libreoffice-calc.desktop
